# Enforce LF for all text files
* text=auto eol=lf

# Explicit LF for source files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.env* text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.db binary